# Telegram bot token (get from @BotFather on Telegram)
BOT_TOKEN=your_telegram_bot_token_here

# Path to sqlite DB file (use /tmp/focusflow.sqlite on Railway)
DATABASE_PATH=./focusflow.sqlite

# Deriv WebSocket URL (use wss://ws.derivws.com/websockets/v3?app_id=1089 for production)
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3?app_id=1089

# Default per-user alert cooldown seconds
DEFAULT_ALERT_COOLDOWN=300